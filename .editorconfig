# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sln,slnx,csproj,props,targets}]
indent_size = 2

[*.cs]
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_new_line_before_open_brace = all
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = false

# SA1200: Allow using directives outside of namespace
dotnet_diagnostic.SA1200.severity = none

# SA1600: Disable mandatory XML documentation for all public elements
dotnet_diagnostic.SA1600.severity = none

# SA1309: Allow fields to begin with an underscore (Private fields like _name)
dotnet_diagnostic.SA1309.severity = none

# SA1101: Don't force 'this.' prefix for local members
dotnet_diagnostic.SA1101.severity = none

# SA1402: Allow multiple types in a single file (Useful for small records/markers)
dotnet_diagnostic.SA1402.severity = none

# SA1201: A record struct can follow a class
dotnet_diagnostic.SA1201.severity = none

# SA0001: Disable XML comment analysis warning (e.g. when documentation file is not generated)
dotnet_diagnostic.SA0001.severity = none

# SA1633: File should have XML documentation at the top (File header)
dotnet_diagnostic.SA1633.severity = none

# SA1601: Partial elements should be documented
dotnet_diagnostic.SA1601.severity = none

# SA1602: Enumeration items should be documented
dotnet_diagnostic.SA1602.severity = none

# SA1518 File not required to end with a single newline character
dotnet_diagnostic.SA1518.severity = none

# SA1313: Allow field names to begin with a lowercase letter (e.g. for record parameters)
dotnet_diagnostic.SA1313.severity = none

# SA1009: Closing parenthesis should not be followed by a space
dotnet_diagnostic.SA1009.severity = none

# SA1106: Code should not contain empty statements (e.g. for switch cases)
dotnet_diagnostic.SA1106.severity = none

# IDE0005: Remove unnecessary usings
dotnet_diagnostic.IDE0005.severity = error

# CS8618: Non-nullable field must contain a non-null value when exiting constructor (Suppressed for EF Core)
dotnet_diagnostic.CS8618.severity = none

# SA1010: Opening square brackets should not be preceded by a space (Conflicts with C# 12 [])
dotnet_diagnostic.SA1010.severity = none

# SA1028: Code should not contain trailing whitespace
dotnet_diagnostic.SA1028.severity = none

dotnet_diagnostic.CS0108.severity = none

dotnet_diagnostic.SA1118.severity = none

dotnet_diagnostic.SA1000.severity = none

dotnet_diagnostic.SA1001.severity = none

dotnet_diagnostic.SA1003.severity = none

dotnet_diagnostic.SA1008.severity = none

dotnet_diagnostic.SA1500.severity = none

dotnet_diagnostic.SA1502.severity = none

dotnet_diagnostic.SA1508.severity = none

dotnet_diagnostic.SA1516.severity = none

[*.{ts,tsx,js,jsx}]
ij_typescript_use_double_quotes = false
max_line_length = 100
end_of_line = lf
typescript_spaces_within_imports = true
typescript_spaces_within_object_literal_braces = true

[*.md]
max_line_length = off
trim_trailing_whitespace = false


