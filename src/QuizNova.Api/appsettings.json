{
  "JwtSettings": {
    "Issuer": "QuizNova.Api",
    "Audience": "QuizNova.Client",
    "Secret": "QuizNova-Development-Secret-Key-Change-This-2026",
    "ExpiryMinutes": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "QuizNova.Api"
    }
  },
  "AllowedHosts": "*"
}
